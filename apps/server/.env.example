# =============================================================================
# LLM PROVIDER — set ONE of these. Anthropic is preferred when both are set.
# The server re-reads this file on every LLM call (no restart needed).
# =============================================================================

# Paste your Anthropic key here for Claude (the spec target):
ANTHROPIC_API_KEY=sk-ant-...

# Gemini fallback. Get a free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# =============================================================================
# REST OF CONFIG
# =============================================================================
DATABASE_URL=postgres://postgres:postgres@localhost:5432/healosbench
BETTER_AUTH_SECRET=please_change_me_to_a_32_plus_char_secret_xx
BETTER_AUTH_URL=http://localhost:8787
CORS_ORIGIN=http://localhost:3001
NODE_ENV=development
